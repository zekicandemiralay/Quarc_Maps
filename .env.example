# ─── MapTiler ───────────────────────────────────────────────────────────────
# Free tier at https://maptiler.com (100k tiles/month)
MAPTILER_API_KEY=your_maptiler_key_here

# ─── OpenRouteService ────────────────────────────────────────────────────────
# Free tier at https://openrouteservice.org (2000 routes/day)
ORS_API_KEY=your_ors_key_here

# ─── Transitland (primary feed source for transit auto-download) ─────────────
# Free API key at https://www.transit.land/
TRANSITLAND_API_KEY=your_transitland_key_here

# ─── MobilityData (optional fallback feed source) ────────────────────────────
# Free signup at https://mobilitydatabase.org/
# After login: Account Settings → copy your Refresh Token
MDB_REFRESH_TOKEN=your_mdb_refresh_token_here

# ─── Server ──────────────────────────────────────────────────────────────────
# REQUIRED — the IP address clients use to reach this server.
# This IP is embedded in the self-signed TLS certificate SAN.
# If the IP doesn't match, iOS/Android will reject the cert even after installing it.
#
# Use your Tailscale IP (100.x.x.x) if accessing over Tailscale:
#   tailscale ip -4
# Use your LAN IP if accessing only on the local network:
#   hostname -I | awk '{print $1}'
#
# IMPORTANT: if you change this value, delete the old cert volume and restart:
#   docker volume rm <project>_ssl_certs
#   docker compose up -d
SERVER_IP=100.x.x.x

# ─── Port ────────────────────────────────────────────────────────────────────
FRONTEND_PORT=7300
